# Cache static assets (improves PageSpeed "Use efficient cache lifetimes")
# Netlify: place this file in the publish directory (e.g. root or public)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/styles.css
  Cache-Control: public, max-age=86400

/app.js
  Cache-Control: public, max-age=86400

/paste-rich.js
  Cache-Control: public, max-age=86400

/post-ready-text.js
  Cache-Control: public, max-age=86400
